exports[`generateSemantic > snapshot stability 1`] = `
"/* TestTheme — Semantic Tokens (shadcn/ui compatible) */
:root {
  /* Base */
  --background: var(--color-surface-50);
  --foreground: var(--color-surface-975);
  /* Card */
  --card: var(--color-surface-25);
  --card-foreground: var(--color-surface-975);
  /* Popover */
  --popover: var(--color-surface-25);
  --popover-foreground: var(--color-surface-975);
  /* Primary */
  --primary: var(--color-brand-600);
  --primary-foreground: var(--color-brand-50);
  /* Secondary — softened brand */
  --secondary: var(--color-brand-200);
  --secondary-foreground: var(--color-brand-900);
  /* Muted */
  --muted: var(--color-surface-75);
  --muted-foreground: var(--color-surface-700);
  /* Accent */
  --accent: var(--color-brand-100);
  --accent-foreground: var(--color-brand-950);
  /* Destructive */
  --destructive: var(--color-error-600);
  --destructive-foreground: var(--color-error-surface-100);
  --destructive-subtle: var(--color-error-100);
  --destructive-subtle-foreground: var(--color-error-950);
  --destructive-border: var(--color-error-surface-300);
  /* Border / Input / Ring */
  --border: var(--color-surface-300);
  --border-muted: var(--color-surface-200);
  --input: var(--color-surface-300);
  --ring: var(--color-surface-400);
  /* Shadows */
  --shadow-xs: 0 0.247rem 0.371rem oklch(0.05 0.01 247.90 / 0.052), 0 0.618rem 1.236rem oklch(0.05 0.01 247.90 / 0.078);
  --shadow-sm: 0 0.314rem 0.472rem oklch(0.05 0.01 247.90 / 0.066), 0 0.786rem 1.572rem oklch(0.05 0.01 247.90 / 0.099);
  --shadow-md: 0 0.400rem 0.600rem oklch(0.05 0.01 247.90 / 0.084), 0 1.000rem 2.000rem oklch(0.05 0.01 247.90 / 0.126);
  --shadow-lg: 0 0.509rem 0.763rem oklch(0.05 0.01 247.90 / 0.107), 0 1.272rem 2.544rem oklch(0.05 0.01 247.90 / 0.160);
  --shadow-xl: 0 0.647rem 0.971rem oklch(0.05 0.01 247.90 / 0.136), 0 1.618rem 3.236rem oklch(0.05 0.01 247.90 / 0.204);
  /* Sidebar */
  --sidebar: var(--color-surface-25);
  --sidebar-foreground: var(--color-surface-975);
  --sidebar-primary: var(--color-brand-600);
  --sidebar-primary-foreground: var(--color-brand-50);
  --sidebar-accent: var(--color-brand-100);
  --sidebar-accent-foreground: var(--color-brand-950);
  --sidebar-border: var(--color-surface-300);
  --sidebar-ring: var(--color-surface-400);
}

.dark {
  /* Base */
  --background: var(--color-surface-875);
  --foreground: var(--color-surface-25);
  /* Card */
  --card: var(--color-surface-825);
  --card-foreground: var(--color-surface-25);
  /* Popover */
  --popover: var(--color-surface-800);
  --popover-foreground: var(--color-surface-25);
  /* Primary */
  --primary: var(--color-brand-400);
  --primary-foreground: var(--color-brand-975);
  /* Secondary — softened brand */
  --secondary: var(--color-brand-800);
  --secondary-foreground: var(--color-brand-100);
  /* Muted */
  --muted: var(--color-surface-850);
  --muted-foreground: var(--color-surface-300);
  /* Accent */
  --accent: var(--color-brand-800);
  --accent-foreground: var(--color-brand-50);
  /* Destructive */
  --destructive: var(--color-error-400);
  --destructive-foreground: var(--color-error-surface-900);
  --destructive-subtle: var(--color-error-800);
  --destructive-subtle-foreground: var(--color-error-50);
  --destructive-border: var(--color-error-surface-700);
  /* Border / Input / Ring */
  --border: var(--color-surface-600);
  --border-muted: var(--color-surface-700);
  --input: var(--color-surface-700);
  --ring: var(--color-surface-500);
  /* Shadows */
  --shadow-xs: 0 0.247rem 0.371rem oklch(0.02 0.005 258.37 / 0.104), 0 0.618rem 1.236rem oklch(0.02 0.005 258.37 / 0.156);
  --shadow-sm: 0 0.314rem 0.472rem oklch(0.02 0.005 258.37 / 0.132), 0 0.786rem 1.572rem oklch(0.02 0.005 258.37 / 0.198);
  --shadow-md: 0 0.400rem 0.600rem oklch(0.02 0.005 258.37 / 0.168), 0 1.000rem 2.000rem oklch(0.02 0.005 258.37 / 0.252);
  --shadow-lg: 0 0.509rem 0.763rem oklch(0.02 0.005 258.37 / 0.214), 0 1.272rem 2.544rem oklch(0.02 0.005 258.37 / 0.321);
  --shadow-xl: 0 0.647rem 0.971rem oklch(0.02 0.005 258.37 / 0.272), 0 1.618rem 3.236rem oklch(0.02 0.005 258.37 / 0.408);
  /* Sidebar */
  --sidebar: var(--color-surface-875);
  --sidebar-foreground: var(--color-surface-25);
  --sidebar-primary: var(--color-brand-400);
  --sidebar-primary-foreground: var(--color-brand-975);
  --sidebar-accent: var(--color-brand-800);
  --sidebar-accent-foreground: var(--color-brand-50);
  --sidebar-border: var(--color-surface-600);
  --sidebar-ring: var(--color-surface-500);
}
"
